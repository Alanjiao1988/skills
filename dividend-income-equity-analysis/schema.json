{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dividend Income Equity Analysis",
  "type": "object",
  "properties": {
    "company": {"type": "string"},
    "ticker": {"type": "string"},
    "exchange": {"type": "string"},
    "as_of_date": {"type": "string"},
    "domicile": {"type": "string"},
    "security_type": {"type": "string"},
    "price_used": {"type": "number"},
    "gross_yield": {"type": "number", "description": "Decimal form, e.g. 0.06 for 6%"},
    "net_yield": {"type": "number", "description": "Decimal form, e.g. 0.054 for 5.4%"},
    "normalized_dps": {"type": ["number", "null"]},
    "normalized_net_yield": {"type": ["number", "null"], "description": "Decimal form"},
    "withholding_rate": {"type": "number", "description": "Decimal form, e.g. 0.10 for 10%"},
    "withholding_basis": {"type": "string", "enum": ["broker_observed", "company_announcement", "legal_structure", "market_default", "unknown"]},
    "broker_observed_withholding": {"type": "string", "enum": ["Yes", "No", "Unknown"]},
    "dividend_quality": {"type": "string", "enum": ["High", "Medium", "Low"]},
    "dividend_safety": {"type": "string", "enum": ["Strong", "Acceptable", "Weak", "Unclear"]},
    "withholding_efficiency": {"type": "string", "enum": ["High", "Medium", "Low"]},
    "buyback_quality": {"type": "string", "enum": ["Good", "Neutral", "Poor", "Not Applicable"]},
    "three_year_outlook": {"type": "string", "enum": ["Grow", "Stable", "Decline", "High Uncertainty"]},
    "portfolio_role": {"type": "string", "enum": ["Core income", "Cyclical income", "Opportunistic", "Watchlist", "Avoid"]},
    "score_100": {"type": "number", "minimum": 0, "maximum": 100},
    "dividend_snapshot": {
      "type": "object",
      "properties": {
        "ttm_dps": {"type": ["number", "null"]},
        "ttm_net_yield": {"type": ["number", "null"]},
        "normalized_dps": {"type": ["number", "null"]},
        "normalized_net_yield": {"type": ["number", "null"]},
        "five_year_dps_range": {"type": "string"},
        "latest_dps_yoy": {"type": "string"},
        "dividend_type": {"type": "string"},
        "coverage_status": {"type": "string"}
      }
    },
    "five_year_dividend_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fiscal_year": {"type": "string"},
          "total_dps": {"type": ["number", "null"]},
          "base_dps": {"type": ["number", "null"]},
          "special_or_variable_dps": {"type": ["number", "null"]},
          "dps_yoy": {"type": ["number", "null"], "description": "Decimal form"},
          "yield_at_current_price": {"type": ["number", "null"], "description": "Decimal form"},
          "yield_at_year_price": {"type": ["number", "null"], "description": "Decimal form"},
          "withholding_rate": {"type": ["number", "null"]},
          "net_dps": {"type": ["number", "null"]},
          "net_yield": {"type": ["number", "null"]},
          "dividend_type": {"type": "string"},
          "quality_tag": {"type": "string"},
          "notes": {"type": "string"}
        },
        "required": ["fiscal_year"]
      }
    },
    "cash_flow_bridge": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fiscal_year": {"type": "string"},
          "net_income": {"type": ["number", "null"]},
          "operating_cash_flow": {"type": ["number", "null"]},
          "capex": {"type": ["number", "null"]},
          "free_cash_flow": {"type": ["number", "null"]},
          "cash_dividends": {"type": ["number", "null"]},
          "buybacks": {"type": ["number", "null"]},
          "share_issuance": {"type": ["number", "null"]},
          "net_debt_change": {"type": ["number", "null"]},
          "fcf_dividend_coverage": {"type": ["number", "null"]},
          "funding_source": {"type": "string"}
        },
        "required": ["fiscal_year"]
      }
    },
    "three_year_forecast": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fiscal_year": {"type": "string"},
          "scenario": {"type": "string", "enum": ["Bear", "Base", "Bull"]},
          "dps": {"type": ["number", "null"]},
          "net_yield_at_current_price": {"type": ["number", "null"]},
          "estimated_fcf": {"type": ["number", "null"]},
          "dividend_cash_cost": {"type": ["number", "null"]},
          "fcf_dividend_coverage": {"type": ["number", "null"]},
          "balance_sheet_impact": {"type": "string"},
          "key_assumptions": {"type": "string"}
        },
        "required": ["fiscal_year", "scenario", "key_assumptions"]
      }
    },
    "visual_summary": {
      "type": "object",
      "properties": {
        "dps_path": {"type": "string"},
        "yield_normalization": {"type": "string"},
        "coverage_labels": {"type": "string"}
      }
    },
    "sources": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["company", "ticker", "exchange", "as_of_date", "gross_yield", "net_yield", "withholding_rate", "withholding_basis", "score_100"]
}
